modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["unzip"]

[[ports]]
localPort = 5000
externalPort = 80

[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
run = ["node", "./dist/index.cjs"]
build = ["node_modules/.bin/vite", "build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[userenv]

[userenv.shared]
SARAH_BRIDGE_SECRET = "sarah_bridge_secure_2026"
LEXI_NATIVE_BRIDGE_SECRET = "lexi-native-bridge-2026"
EMAIL_FROM = "CompanySync <noreply@companysync.io>"
ENCRYPTION_KEY = "bdfc09526259c1b2e69f1e5a6dfd8c18ecd011c13be950a64762ce1c193c8c3a"
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = "io.companysync@gmail.com"
VITE_REPLIT_APP_URL = "https://code-analyzer-1.replit.app"
VITE_BASE44_FUNCTIONS_URL = "https://code-analyzer-1.replit.app/api/functions"
BASE44_SARAH_API_URL = "https://code-analyzer-1.replit.app/api/functions/sarahBridgeAPI"
BASE44_LEXI_BRIDGE_API_URL = "https://code-analyzer-1.replit.app/api/functions/lexiVoiceBridge"

[agent]
